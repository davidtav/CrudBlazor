@page "/pessoas/delete/{Id:int}"
@using LearnCrudBlazor.Data
@using LearnCrudBlazor.Model
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavigationManager

<h3>Delete Pessoa</h3>

@if (Pessoa is null)
{
    <p>Loading...</p>
}
else
{
    <h4>Are you sure you want to delete this record?</h4>

    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Pessoa.Nome</dd>

        <dt class="col-sm-2">Sobrenome</dt>
        <dd class="col-sm-10">@Pessoa.Sobrenome</dd>

        <dt class="col-sm-2">Idade</dt>
        <dd class="col-sm-10">@Pessoa.Idade</dd>
    </dl>

    <EditForm Model="@Pessoa" OnValidSubmit="@DeletePessoa" FormName="delete-pessoa">
        <InputNumber @bind-Value="Pessoa.Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-secondary ms-2" href="/pessoas">Back to List</a>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    [SupplyParameterFromForm]
    private Pessoa? Pessoa { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Pessoa ??= await context.Pessoas.FindAsync(Id);
    }

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task DeletePessoa()
    {
        if (Pessoa is null)
            return;

        using var context = DbFactory.CreateDbContext();
        context.Pessoas.Remove(Pessoa);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/pessoas");
    }
}

